# SPC 2.0 Network Watchdog — Design Stub
#
# This service monitors upstream connectivity and toggles the local AP fallback
# when the site network is unavailable.
#
# STATUS: Design stub — not yet implemented for Build 1A.
#         Implement in Build 1B (Yard) before outdoor deployment.
#
# Implementation notes:
#   - Script: /usr/local/bin/spc20-network-watchdog.sh (to be written)
#   - Check interval: 60 seconds
#   - Upstream test: ping -c 2 -W 3 8.8.8.8 (or site gateway)
#   - Grace period: 90 seconds of failed pings before AP activation
#   - Activation: nmcli connection up spc20-ap
#   - Deactivation: nmcli connection down spc20-ap && nmcli connection up site-wifi
#   - Log all transitions: logger -t spc20-watchdog "<msg>"

[Unit]
Description=SPC 2.0 Network Watchdog — upstream monitor and AP fallback
Documentation=file:///opt/spc20/docs/local_ap_fallback.md
After=network-online.target NetworkManager.service
Wants=network-online.target
# Restart if the watchdog script crashes
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
# Replace with path to watchdog script when implemented
ExecStart=/usr/local/bin/spc20-network-watchdog.sh
Restart=on-failure
RestartSec=30s

# Security hardening
User=root
# root required for nmcli connection commands; consider polkit in later builds

# Environment — script reads these to know which profiles to switch
Environment="SPC20_AP_PROFILE=spc20-ap"
Environment="SPC20_SITE_PROFILE=site-wifi"
Environment="SPC20_PING_HOST=8.8.8.8"
Environment="SPC20_CHECK_INTERVAL_SEC=60"
Environment="SPC20_GRACE_PERIOD_SEC=90"

# Log to journald
StandardOutput=journal
StandardError=journal
SyslogIdentifier=spc20-watchdog

[Install]
WantedBy=multi-user.target

