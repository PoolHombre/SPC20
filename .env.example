# ─── Device identity ───────────────────────────────────────────────────────────
DEVICE_ID=spc20-b1-bench-0001
DEVICE_TOKEN=replace-with-per-device-token

# ─── Trial tracking ────────────────────────────────────────────────────────────
TRIAL_PHASE=BENCH
TRIAL_RUN_ID=
SITE_ID=

# ─── Hardware adapter: sequent | simulator ────────────────────────────────────
SENSOR_ADAPTER=simulator
SIM_SCENARIO=green

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_INGEST_URL=https://<project-ref>.supabase.co/functions/v1/spc20-ingest
# SUPABASE_SERVICE_ROLE_KEY must NEVER be set on device

# ─── Local storage ────────────────────────────────────────────────────────────
LOCAL_DB_PATH=/var/lib/spc20/spc20.db

# ─── Local web dashboard ──────────────────────────────────────────────────────
LOCAL_WEB_BIND_HOST=0.0.0.0
LOCAL_WEB_PORT=8080
LOCAL_WEB_USERNAME=tech
# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
LOCAL_WEB_PASSWORD_HASH=
# Dashboard port (used by app.py / gunicorn)
WEB_PORT=8080
# Fallback plain password (not recommended for field use)
DASHBOARD_PASSWORD=

# ─── Pool / sensor configuration ──────────────────────────────────────────────
REQUIRED_FLOW_GPM=333
POOL_VOLUME_GAL=120000
P1_MIN_PSI=-15
P1_MAX_PSI=30
P2_MIN_PSI=0
P2_MAX_PSI=100
P3_MIN_PSI=0
P3_MAX_PSI=100
FLOW_MIN_GPM=0
FLOW_MAX_GPM=500

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
