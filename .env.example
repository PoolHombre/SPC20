# Device identity
DEVICE_ID=spc20-poc-0001
DEVICE_TOKEN=replace-with-per-device-token

# Supabase (device-facing ingest URL only — SUPABASE_SERVICE_ROLE_KEY must NEVER be on device)
SUPABASE_INGEST_URL=https://<project-ref>.supabase.co/functions/v1/spc20-ingest

# Hardware adapter: "sequent" for real HAT, "simulator" for bench/yard testing
SENSOR_ADAPTER=simulator

# Trial metadata
TRIAL_PHASE=bench
TRIAL_RUN_ID=

# Logging
LOG_LEVEL=INFO

# Storage (writable path for SQLite DB)
LOCAL_DB_PATH=/var/lib/spc20/spc20.db

# Dashboard (store bcrypt hash, not raw password)
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
DASHBOARD_PASSWORD_HASH=
# Fallback (plain, not recommended for production)
DASHBOARD_PASSWORD=

# Web dashboard port
WEB_PORT=8080

